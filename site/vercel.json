{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/image-sitemap.xml", "destination": "/api/image-sitemap.xml" }
  ],
  "headers": [
    {
      "source": "/robots.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain" }]
    },
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml" }]
    }
  ]
}
